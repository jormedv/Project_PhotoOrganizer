# Photo Organizer configuration
# Copy this file to .env.photoorganizer and fill in your values.
# Passwords are NOT stored here — they are fetched from Bitwarden at runtime via GSM.

# Directory where photos (album.zip, organized_album.zip) are stored
DATA_DIR=/home/jorge/data/Project_PhotoOrganizer

# Directory where log files are written
LOG_DIR=/home/jorge/log/Project_PhotoOrganizer

# Google Photos shared album URL to download
GOOGLE_PHOTOS_ALBUM_URL=https://photos.google.com/share/AF1QipPKstyDa-f6KnXLwuzukksNQjsBGhrBQFRLBqZdKqw2AoTJ773DqnOUf06QBT9m7A?obfsgid=106615097338837901788

# Chrome user data directory for Playwright persistent context
# (default: ~/.config/google-chrome-playwright)
CHROME_USER_DATA_DIR=/home/jorge/.config/google-chrome-playwright

# Google Cloud project ID where the Bitwarden master password secret lives
GCP_PROJECT=jmv-linux-gcloud

# Name of the secret in Google Secret Manager holding the BW master password
GSM_SECRET=JMV-BW
